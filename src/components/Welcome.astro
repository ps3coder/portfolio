---
/**
 * Welcome — Hero placeholder.
 * Video + hero copy removed to make room for new design.
 */
import site from "../data/site.json";

const hero = site.hero;
---

<section id="hero" aria-label="Hero">
	<div class="hero-stripe" aria-hidden="true"></div>
	<div class="hero-inner">
		<div class="hero-left">
			<h1 class="hero-name">
				{hero.identity}
				<img
					class="hero-wave"
					src={hero.waveSrc}
					alt="Waving hand"
					width="64"
					height="64"
					loading="eager"
					decoding="async"
				/>
			</h1>
			<p class="hero-subtitle">{hero.label}</p>
			<p class="hero-intro" set:html={hero.introHtml}></p>
			<nav class="hero-ctas" aria-label="Hero links">
				{hero.ctas?.map((cta) => (
					<a class="hero-cta" href={cta.href}>
						{cta.label}
					</a>
				))}
			</nav>
		</div>

		<div class="hero-right" aria-hidden="true">
			<img
				class="hero-portrait"
				src={hero.portraitSrc}
				alt=""
				loading="eager"
				decoding="async"
				fetchpriority="high"
			/>
		</div>
	</div>
</section>

<style is:global>
	#hero {
		position: relative;
		width: 100%;
		min-height: 100vh;
		background: var(--color-bg);
	}

	#hero .hero-inner {
		position: relative;
		min-height: 100vh;
		display: grid;
		align-items: center;
		padding: clamp(2.25rem, 6vw, 4rem);
	}

	#hero .hero-left {
		position: relative;
		max-width: 44rem;
	}

	#hero .hero-right {
		display: none;
	}

	#hero .hero-portrait {
		display: block;
		width: 100%;
		height: auto;
	}

	#hero .hero-stripe {
		display: none;
	}

	#hero .hero-name {
		position: relative;
		margin: 0;
		display: inline-flex;
		align-items: center;
		gap: 12px;
		font-family: 'Louis George Cafe', system-ui, sans-serif;
		font-weight: 700;
		font-size: clamp(2.5rem, 4.6vw, 3.75rem);
		line-height: 1.02;
		letter-spacing: -0.02em;
		color: var(--color-ink);
	}

	#hero .hero-wave {
		width: 64px;
		height: 64px;
		scale: 1.4;
	}

	#hero .hero-subtitle {
		position: relative;
		margin: 0.35rem 0 0 0;
		font-family: 'Louis George Cafe', system-ui, sans-serif;
		font-weight: 400;
		font-size: clamp(1.05rem, 1.55vw, 1.25rem);
		line-height: 1.2;
		color: rgba(0, 0, 0, 0.7);
	}

	[data-theme='dark'] #hero .hero-subtitle,
	[data-theme='dim'] #hero .hero-subtitle,
	[data-theme='gray'] #hero .hero-subtitle {
		color: rgba(255, 255, 255, 0.75);
	}

	#hero .hero-intro {
		position: relative;
		margin: 2.15rem 0 0 0;
		max-width: 32rem;
		font-family: 'Louis George Cafe', system-ui, sans-serif;
		font-weight: 300;
		font-size: 1.65rem;
		line-height: 1.55;
		letter-spacing: 0.01em;
		color: rgba(0, 0, 0, 0.6);
	}

	#hero .hero-ctas {
		margin-top: 182px;
		display: flex;
		gap: 2.25rem;
		align-items: center;
		flex-wrap: wrap;
		font-family: 'Louis George Cafe', system-ui, sans-serif;
		font-weight: 400;
		font-size: 1.1rem;
		letter-spacing: 0.01em;
	}

	#hero .hero-cta {
		color: var(--color-ink);
		text-decoration: none;
	}

	#hero .hero-cta:hover,
	#hero .hero-cta:focus-visible {
		text-decoration: none;
	}

	[data-theme='dark'] #hero .hero-cta,
	[data-theme='dim'] #hero .hero-cta,
	[data-theme='gray'] #hero .hero-cta {
		color: rgba(255, 255, 255, 0.85);
	}

	#hero .hero-intro-pipe {
		display: inline-block;
		margin-right: 0.4rem;
		color: rgba(0, 0, 0, 0.55);
	}

	[data-theme='dark'] #hero .hero-intro,
	[data-theme='dim'] #hero .hero-intro,
	[data-theme='gray'] #hero .hero-intro {
		color: rgba(255, 255, 255, 0.65);
	}

	[data-theme='dark'] #hero .hero-intro-pipe,
	[data-theme='dim'] #hero .hero-intro-pipe,
	[data-theme='gray'] #hero .hero-intro-pipe {
		color: rgba(255, 255, 255, 0.6);
	}

	/* PC view: match the reference positioning (stable at 110% zoom). */
	@media screen and (min-width: 1024px) {
		#hero {
			height: 103vh;
			min-height: 0;
		}

		#hero .hero-inner {
			height: 103vh;
			min-height: 0;
		}

		#hero .hero-intro {
			margin-top: 1.75rem;
			font-size: 1.8rem;
			line-height: 1.62;
		}

		#hero .hero-inner {
			align-items: start;
			grid-template-columns: minmax(520px, 1fr) minmax(320px, 560px);
			column-gap: clamp(2.25rem, 5vw, 5rem);
			/* Avoid vh/vw here — they change when browser zoom changes. */
			padding-top: 12.75rem;
			padding-left: 4.25rem;
			padding-right: 4.25rem;
			padding-bottom: 0rem;
		}

		#hero .hero-right {
			display: flex;
			justify-content: flex-end;
			align-items: flex-end;
			height: 100%;
			z-index: 1;
		}

		#hero .hero-portrait {
			height: 100%;
			width: auto;
			max-width: 560px;
			object-fit: contain;
			filter: grayscale(0.9);
			position: relative;
			top: -160px;
			left: -55px;
			transform: scale(1.35);
		}

		#hero .hero-stripe {
			display: block;
			position: absolute;
			left: 3.25rem;
			right: 3.25rem;
			top: 12.5rem;
			height: 6.5rem;
			background: #f59794;
			opacity: 0.35;
			pointer-events: none;
			z-index: 0;
		}

		#hero .hero-left {
			z-index: 1;
		}
	}

	/* Mobile + tablet: keep hero as a blank screen for now */
	@media screen and (max-width: 1024px) {
		#hero {
			min-height: 100vh;
			/* Quick-tweak spacing knobs (edit these) */
			--hero-pad-top: 18.5rem;
			--hero-pad-right: 1.5rem;
			--hero-pad-bottom: 2.5rem;
			--hero-pad-left: 1.2rem;
			/* Stripe knobs (edit these) */
			--hero-stripe-top: calc(var(--hero-pad-top) - 0.3rem);
			--hero-stripe-height: 5.6rem;
			--hero-stripe-left: calc(var(--hero-pad-left) - 0.4rem);
			--hero-stripe-right: calc(var(--hero-pad-right) - 0.5rem);
			--hero-stripe-height: 5rem;
			/* Intro spacing knobs (edit these) */
			--hero-intro-margin-top: 2.25rem;
			--hero-intro-margin-right: 0rem;
			--hero-intro-margin-bottom: 0rem;
			--hero-intro-margin-left: 0rem;
			/* Intro typography knobs (edit these) */
			--hero-intro-font-size: 1.4rem;
			--hero-intro-line-height: 1.2;
			--hero-intro-max-width: 15.5rem;
			/* Portrait knobs (edit these) */
			--hero-portrait-top: auto;
			--hero-portrait-right: auto;
			--hero-portrait-bottom: -1rem;
			--hero-portrait-left: 7.2rem;
			--hero-portrait-width: min(92vw, 420px);
			--hero-portrait-height: auto;
			--hero-portrait-max-height: 62vh;

			/* CTA group knobs (edit these) */
			--hero-ctas-top: 28rem;
			--hero-ctas-right: auto;
			--hero-ctas-bottom: auto;
			--hero-ctas-left: 0.2rem;
			--hero-ctas-width: auto;
			--hero-ctas-max-width: 18rem;
			--hero-ctas-gap: 0.95rem;
			--hero-ctas-font-size: 1.05rem;
			--hero-ctas-line-height: 1.2;
			--hero-ctas-letter-spacing: 0.01em;
			--hero-ctas-color: var(--color-ink);
		}

		/* Mobile/tablet: show introHtml + portrait + CTAs */
		#hero .hero-stripe {
			display: none !important;
		}

		#hero .hero-inner {
			min-height: 100vh;
			align-items: start;
			align-content: start;
			padding: var(--hero-pad-top) var(--hero-pad-right) var(--hero-pad-bottom) var(--hero-pad-left);
		}

		#hero .hero-stripe {
			display: block !important;
			position: absolute;
			left: var(--hero-stripe-left);
			right: var(--hero-stripe-right);
			top: var(--hero-stripe-top);
			height: var(--hero-stripe-height);
			background: #f59794;
			opacity: 0.35;
			pointer-events: none;
			z-index: 0;
		}

		#hero .hero-left {
			z-index: 1;
		}

		#hero .hero-right {
			display: block !important;
			position: absolute;
			top: var(--hero-portrait-top);
			right: var(--hero-portrait-right);
			bottom: var(--hero-portrait-bottom);
			left: var(--hero-portrait-left);
			width: var(--hero-portrait-width);
			height: var(--hero-portrait-height);
			max-height: var(--hero-portrait-max-height);
			pointer-events: none;
			z-index: 1;
		}

		#hero .hero-portrait {
			width: 100%;
			height: 100%;
			max-height: inherit;
			object-fit: contain;
			filter: grayscale(0.9);
		}

		#hero .hero-intro {
			display: block;
			margin: var(--hero-intro-margin-top) var(--hero-intro-margin-right) var(--hero-intro-margin-bottom)
				var(--hero-intro-margin-left);
			font-size: var(--hero-intro-font-size);
			line-height: var(--hero-intro-line-height);
			max-width: var(--hero-intro-max-width);
			width: 100%;
		}

		#hero .hero-ctas {
			display: flex !important;
			flex-direction: column;
			flex-wrap: nowrap;
			align-items: flex-start;
			align-content: flex-start;
			gap: var(--hero-ctas-gap);
			position: absolute;
			top: var(--hero-ctas-top);
			right: var(--hero-ctas-right);
			bottom: var(--hero-ctas-bottom);
			left: var(--hero-ctas-left);
			width: var(--hero-ctas-width);
			max-width: var(--hero-ctas-max-width);
			margin: 0;
			font-size: var(--hero-ctas-font-size);
			line-height: var(--hero-ctas-line-height);
			letter-spacing: var(--hero-ctas-letter-spacing);
			color: var(--hero-ctas-color);
			z-index: 2;
		}

		#hero .hero-ctas .hero-cta {
			color: inherit;
			text-decoration: none;
			width: fit-content;
		}

		#hero .hero-name {
			font-size: clamp(2.25rem, 9vw, 3.1rem);
		}

		#hero .hero-wave {
			width: 34px;
			height: 34px;
			scale: 1.9;
			margin-bottom: 10px;
		}
	}
</style>
