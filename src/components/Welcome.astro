---
/**
 * Welcome — Hero placeholder.
 * Video + hero copy removed to make room for new design.
 */
import site from "../data/site.json";

const hero = site.hero;
---

<section id="hero" aria-label="Hero">
	<div class="hero-stripe" aria-hidden="true"></div>
	<div class="hero-inner">
		<div class="hero-left">
			<h1 class="hero-name">
				{hero.identity}
				<img
					class="hero-wave"
					src={hero.waveSrc}
					alt="Waving hand"
					loading="eager"
					decoding="async"
				/>
			</h1>
			<p class="hero-subtitle">{hero.label}</p>
			<p class="hero-intro" set:html={hero.introHtml} />
			<nav class="hero-ctas" aria-label="Hero links">
				{hero.ctas?.map((cta) => (
					<a class="hero-cta" href={cta.href}>
						{cta.label}
					</a>
				))}
			</nav>
		</div>

		<div class="hero-right" aria-hidden="true">
			<img
				class="hero-portrait"
				src={hero.portraitSrc}
				alt=""
				loading="eager"
				decoding="async"
				fetchpriority="high"
			/>
		</div>
	</div>
</section>

<style is:global>
	#hero {
		position: relative;
		width: 100%;
		min-height: 100vh;
		background: var(--color-bg);
	}

	#hero .hero-inner {
		position: relative;
		min-height: 100vh;
		display: grid;
		align-items: center;
		padding: clamp(2.25rem, 6vw, 4rem);
	}

	#hero .hero-left {
		position: relative;
		max-width: 44rem;
	}

	#hero .hero-right {
		display: none;
	}

	#hero .hero-portrait {
		display: block;
		width: 100%;
		height: auto;
	}

	#hero .hero-stripe {
		display: none;
	}

	#hero .hero-name {
		position: relative;
		margin: 0;
		display: inline-flex;
		align-items: center;
		gap: 12px;
		font-family: 'Louis George Cafe', system-ui, sans-serif;
		font-weight: 700;
		font-size: clamp(2.5rem, 4.6vw, 3.75rem);
		line-height: 1.02;
		letter-spacing: -0.02em;
		color: var(--color-ink);
	}

	#hero .hero-wave {
		width: 64px;
		height: 64px;
		scale: 1.4;
	}

	#hero .hero-subtitle {
		position: relative;
		margin: 0.35rem 0 0 0;
		font-family: 'Louis George Cafe', system-ui, sans-serif;
		font-weight: 400;
		font-size: clamp(1.05rem, 1.55vw, 1.25rem);
		line-height: 1.2;
		color: rgba(0, 0, 0, 0.7);
	}

	[data-theme='dark'] #hero .hero-subtitle,
	[data-theme='dim'] #hero .hero-subtitle,
	[data-theme='gray'] #hero .hero-subtitle {
		color: rgba(255, 255, 255, 0.75);
	}

	#hero .hero-intro {
		position: relative;
		margin: 2.15rem 0 0 0;
		max-width: 32rem;
		font-family: 'Louis George Cafe', system-ui, sans-serif;
		font-weight: 300;
		font-size: 1.65rem;
		line-height: 1.55;
		letter-spacing: 0.01em;
		color: rgba(0, 0, 0, 0.6);
	}

	#hero .hero-ctas {
		margin-top: 182px;
		display: flex;
		gap: 2.25rem;
		align-items: center;
		flex-wrap: wrap;
		font-family: 'Louis George Cafe', system-ui, sans-serif;
		font-weight: 400;
		font-size: 1.1rem;
		letter-spacing: 0.01em;
	}

	#hero .hero-cta {
		color: var(--color-ink);
		text-decoration: none;
	}

	#hero .hero-cta:hover,
	#hero .hero-cta:focus-visible {
		text-decoration: none;
	}

	[data-theme='dark'] #hero .hero-cta,
	[data-theme='dim'] #hero .hero-cta,
	[data-theme='gray'] #hero .hero-cta {
		color: rgba(255, 255, 255, 0.85);
	}

	#hero .hero-intro-pipe {
		display: inline-block;
		margin-right: 0.4rem;
		color: rgba(0, 0, 0, 0.55);
	}

	[data-theme='dark'] #hero .hero-intro,
	[data-theme='dim'] #hero .hero-intro,
	[data-theme='gray'] #hero .hero-intro {
		color: rgba(255, 255, 255, 0.65);
	}

	[data-theme='dark'] #hero .hero-intro-pipe,
	[data-theme='dim'] #hero .hero-intro-pipe,
	[data-theme='gray'] #hero .hero-intro-pipe {
		color: rgba(255, 255, 255, 0.6);
	}

	/* PC view: match the reference positioning (stable at 110% zoom). */
	@media screen and (min-width: 1024px) {
		#hero {
			height: 103vh;
			min-height: 0;
		}

		#hero .hero-inner {
			height: 103vh;
			min-height: 0;
		}

		#hero .hero-intro {
			margin-top: 1.75rem;
			font-size: 1.8rem;
			line-height: 1.62;
		}

		#hero .hero-inner {
			align-items: start;
			grid-template-columns: minmax(520px, 1fr) minmax(320px, 560px);
			column-gap: clamp(2.25rem, 5vw, 5rem);
			/* Avoid vh/vw here — they change when browser zoom changes. */
			padding-top: 12.75rem;
			padding-left: 4.25rem;
			padding-right: 4.25rem;
			padding-bottom: 0rem;
		}

		#hero .hero-right {
			display: flex;
			justify-content: flex-end;
			align-items: flex-end;
			height: 100%;
			z-index: 1;
		}

		#hero .hero-portrait {
			height: 100%;
			width: auto;
			max-width: 560px;
			object-fit: contain;
			filter: grayscale(0.9);
			position: relative;
			top: -160px;
			left: -55px;
			transform: scale(1.35);
		}

		#hero .hero-stripe {
			display: block;
			position: absolute;
			left: 3.25rem;
			right: 3.25rem;
			top: 12.5rem;
			height: 6.5rem;
			background: #f59794;
			opacity: 0.35;
			pointer-events: none;
			z-index: 0;
		}

		#hero .hero-left {
			z-index: 1;
		}
	}
</style>
