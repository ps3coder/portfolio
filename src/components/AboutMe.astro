---
/**
 * AboutMe — Intro + background copy and links.
 * Uses global theme vars from src/styles/theme.css (--color-bg, --color-ink, --color-link).
 * Copy: src/data/site.json → about
 */
import site from '../data/site.json';

const baseUrl = import.meta.env.BASE_URL.endsWith('/')
	? import.meta.env.BASE_URL
	: `${import.meta.env.BASE_URL}/`;

const { about } = site;
---

<link rel="stylesheet" href="https://fonts.cdnfonts.com/css/pp-neue-montreal" />

<section class="about-section" id="about" aria-label="About me">
  <div class="about-page">
    <div class="about-intro">
      <h1 class="about-title">
        {about.introTitle}
      </h1>
    
      {about.introParagraphs.map((p) => (
        <p class="about-paragraph">{p}</p>
      ))}
    
      <p class="about-paragraph">
        {about.outreachPrefix}{' '}
        <a class="about-link" href={`mailto:${about.email}`}>{about.email}</a>
      </p>
    
      <p class="about-links">
        {about.social.map((s, i) => (
          <>
            {i > 0 && <span class="about-sep">|</span>}
            <a class="about-link" href={s.href} target="_blank" rel="noopener">{s.label}</a>
          </>
        ))}
        <span class="about-sep">|</span>
        <a class="about-link" href={`${baseUrl}${about.resume.file}`} target="_blank" rel="noopener">{about.resume.label}</a>
      </p>
    
      <p class="about-paragraph about-paragraph--spaced">
        {about.closingParagraph}
      </p>
    </div>
    

    <div class="about-background" aria-label="Background">
      <h2 class="about-background-title">{about.backgroundTitle}</h2>
    
      {about.backgroundParagraphs.map((p) => (
        <p class="about-background-text">{p}</p>
      ))}
    </div>
    
  </div>
</section>

<style>
  /* Section uses central theme; no hardcoded hex. */
  .about-section {
    background: var(--color-bg);
    color: var(--color-ink);
  }

  .about-page {
    max-width: 1270px;
    margin: 0 auto;
    padding: 2.78rem 2.78rem 4rem;
    min-height: 100vh;
    font-family: "PP Neue Montreal", "NeueMontreal-Regular", -apple-system, BlinkMacSystemFont, "Segoe UI", Helvetica, Arial, sans-serif;
  }

  .about-title {
    margin: 0 0 1.67rem;
    font-weight: 400;
    font-size: 2.78rem;
    line-height: 3.33rem;
    letter-spacing: 0;
    color: var(--color-ink);
  }

  .about-paragraph {
    margin: 0 0 1rem;
    max-width: 65ch;
    font-size: 1rem;
    line-height: 1.67rem;
    color: var(--color-ink);
  }

  .about-paragraph--spaced {
    margin-top: 2.5rem;
  }

  .about-links {
    margin: 0 0 0;
    font-size: 1rem;
    line-height: 1.67rem;
  }

  .about-sep {
    margin: 0 0.4rem;
    color: var(--color-ink);
  }

  .about-link {
    color: var(--color-link);
    text-decoration: underline;
  }

  .about-link:hover,
  .about-link:focus-visible {
    color: var(--color-link-hover);
  }

  /* Background subsection: heading + stacked paragraphs */
  .about-background {
    margin-top: 3.5rem;
    padding-top: 0.5rem;
  }

  .about-background-title {
    margin: 0 0 1rem;
    font-weight: 400;
    font-size: 1.33rem;
    line-height: 1.4;
    letter-spacing: 0;
    color: var(--color-ink);
  }

  .about-background-text {
    margin: 0 0 1rem;
    max-width: 65ch;
    font-size: 1rem;
    line-height: 1.67rem;
    color: var(--color-ink);
  }

  @media screen and (max-width: 768px) {
    .about-page {
      padding: 2rem 1.5rem 3rem;
    }

    .about-title {
      font-size: 2.22rem;
      line-height: 2.78rem;
    }

    .about-paragraph--spaced {
      margin-top: 1.75rem;
    }

    .about-background {
      margin-top: 2.5rem;
    }
  }
</style>
